#!/bin/bash
# hk-action — play a random 3-layer Hollow Knight combat sound
# Picks one random file from each layer (voice + movement + hit)
# and plays all three simultaneously. Every action = APM dopamine.
#
# Usage: hk-action
# Drop .wav files into the layer folders to expand the pool.

GAMIFY_SOUNDS="${GAMIFY_SOUNDS:-$HOME/.local/share/gamify/sounds}"
BASE="$GAMIFY_SOUNDS/user-action"

pick() {
  local files=("$1"/*)
  echo "${files[RANDOM % ${#files[@]}]}"
}

afplay "$(pick "$BASE/voice")" &
afplay "$(pick "$BASE/movement")" &
afplay "$(pick "$BASE/hit")" &
